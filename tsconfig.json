{
    "compilerOptions": {
      "target": "es5",                                
      "module": "esnext",   
      "moduleResolution": "node",
      "strict": true,                                 
      "esModuleInterop": true,   
      "allowSyntheticDefaultImports": true,                     
      "skipLibCheck": true,                           
      "forceConsistentCasingInFileNames": true,        
      "outDir": "./public/script"
    },
    "include": ["./src"]
}
  